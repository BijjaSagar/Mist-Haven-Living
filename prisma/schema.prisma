generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

model SiteSettings {
  id                String   @id @default("default")
  siteName          String   @default("Mist & Haven Living")
  legalName         String   @default("Mist & Haven Living")
  tagline           String   @default("Luxury In Every Thread.")
  description       String   @db.Text
  logoUrl           String   @default("/logo.png")
  logoLightUrl      String   @default("/logo-light.png")
  faviconUrl        String?
  colorPearl        String   @default("#fbfaf6")
  colorOat          String   @default("#f1ece2")
  colorTaupe        String   @default("#5e5547")
  colorMuted        String   @default("#857b6c")
  colorSage         String   @default("#c8c7ac")
  colorSageDeep     String   @default("#9a9a7d")
  colorHairline     String   @default("#e7e0d3")
  contactEmail          String
  contactEmailSecondary String?
  contactPhone          String
  leadsToEmail      String?
  resendFromEmail   String?
  inquiryEnabled    Boolean  @default(true)
  whatsappNumber    String?
  calendlyUrl       String?
  footerBlurb       String   @db.Text
  copyrightText     String?
  exportMarkets     String   @default("USA · Canada")
  addressStreet     String
  addressCity       String
  addressRegion     String
  addressCountry    String
  addressPostalCode String
  updatedAt         DateTime @updatedAt
}

model NavigationItem {
  id        String  @id @default(cuid())
  label     String
  href      String
  type      String  @default("link")
  sortOrder Int     @default(0)
  visible   Boolean @default(true)
  location  String

  @@index([location, sortOrder])
}

model ProductCategory {
  id               String   @id @default(cuid())
  slug             String   @unique
  name             String
  shortDescription String   @db.Text
  description      String   @db.Text
  eyebrow          String
  heroImage        String
  cardImage        String
  galleryImages    Json     @default("[]")
  features         Json
  materials        Json
  sizes            Json
  gsmRange         String
  customization    Json
  packaging        Json
  idealFor         Json
  leadTime         String
  moq              String
  metaTitle        String?
  metaDescription  String?  @db.Text
  sortOrder        Int      @default(0)
  visible          Boolean  @default(true)
  updatedAt        DateTime @updatedAt
}

model PageContent {
  slug            String   @id
  metaTitle       String?
  metaDescription String?  @db.Text
  sections        Json
  updatedAt       DateTime @updatedAt
}

model Stat {
  id        String  @id @default(cuid())
  value     String
  label     String
  sortOrder Int     @default(0)
  visible   Boolean @default(true)
}

model Certification {
  id          String  @id @default(cuid())
  name        String
  code        String?
  description String  @db.Text
  pdfUrl      String?
  sortOrder   Int     @default(0)
  visible     Boolean @default(true)
}

model AdminUser {
  id        String   @id @default(cuid())
  email     String   @unique
  password  String
  name      String?
  role      String   @default("admin")
  active    Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Inquiry {
  id              String    @id @default(cuid())
  name            String
  company         String
  country         String
  email           String
  phone           String
  productInterest String
  message         String    @db.Text
  buyerType       String
  estimatedVolume String?
  targetMarket    String?
  source          String    @default("web")
  emailSent       Boolean   @default(false)
  emailError      String?   @db.Text
  readAt          DateTime?
  createdAt       DateTime  @default(now())

  @@index([createdAt])
  @@index([readAt])
}
