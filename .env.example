# MySQL database connection
DATABASE_URL="mysql://user:password@localhost:3306/mist_haven"

# Admin CMS credentials
ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=your-secure-password
# Optional: separate secret for JWT signing (defaults to ADMIN_PASSWORD)
# ADMIN_SECRET=your-jwt-secret

# Resend API key for inquiry form emails
RESEND_API_KEY=re_xxxxxxxxxxxx

# Destination email for B2B lead inquiries
LEADS_TO_EMAIL=export@yourcompany.com

# WhatsApp number for floating chat button (include country code, e.g. +919876543210)
NEXT_PUBLIC_WHATSAPP_NUMBER=+919876543210

# Calendly scheduling URL for "Schedule a Discussion" embed/link
NEXT_PUBLIC_CALENDLY_URL=https://calendly.com/your-team/export-consultation
